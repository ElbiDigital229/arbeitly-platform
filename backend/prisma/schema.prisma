generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CANDIDATE
  EMPLOYEE
  EMPLOYER
  ADMIN
}

enum ApplicationStatus {
  TO_APPLY
  APPLIED
  IN_PROGRESS
  INTERVIEW
  OFFER
  ACCEPTED
  REJECTED
  FAILED
}

enum CandidateFileSource {
  ONBOARDING        // candidate uploaded during onboarding — both candidate and employee see
  CANDIDATE_PRIVATE // candidate uploaded after onboarding — only candidate sees
  EMPLOYEE          // employee uploaded/generated — both see
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  password           String
  role               Role     @default(CANDIDATE)
  assignedEmployeeId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  profile            CandidateProfile?
  cvs                CV[]
  coverLetters       CoverLetter[]
  applications       Application[]
  assignedEmployee   User?    @relation("EmployeeCandidates", fields: [assignedEmployeeId], references: [id])
  assignedCandidates User[]   @relation("EmployeeCandidates")
  addedJobs          JobDiscovery[]
  queueItemsAsCandidate CandidateJobQueue[] @relation("QueueCandidate")
  queueItemsAsEmployee  CandidateJobQueue[] @relation("QueueEmployee")
  faqItemsAsCandidate   FaqItem[]           @relation("FaqCandidate")
  faqItemsAsEmployee    FaqItem[]           @relation("FaqEmployee")
  transactions          Transaction[]
  pendingCheckouts      PendingCheckout[]
  activityLogs          ActivityLog[]
  filesAsCandidate      CandidateFile[]     @relation("FilesCandidate")
  filesAsUploader       CandidateFile[]     @relation("FilesUploader")
}

model CandidateFile {
  id           String   @id @default(cuid())
  candidateId  String
  uploadedById String?
  filename     String
  mimetype     String
  size         Int
  storageKey   String
  label        String?
  source       CandidateFileSource @default(EMPLOYEE)
  createdAt    DateTime @default(now())

  candidate  User  @relation("FilesCandidate", fields: [candidateId], references: [id], onDelete: Cascade)
  uploadedBy User? @relation("FilesUploader", fields: [uploadedById], references: [id])

  @@index([candidateId])
}

model Plan {
  id               String   @id @default(cuid())
  name             String
  description      String?
  price            Float
  currency         String   @default("EUR")
  applicationLimit Int
  cvLimit          Int      @default(10)
  features         Json     @default("[]")
  isActive         Boolean  @default(true)
  isPopular        Boolean  @default(false)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  candidates       CandidateProfile[]
  transactions     Transaction[]
  pendingCheckouts PendingCheckout[]
}

model CandidateProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  firstName            String
  lastName             String
  phone                String?
  location             String?
  bio                  String?
  linkedinUrl          String?
  portfolioUrl         String?
  onboardingCompleted  Boolean  @default(false)
  planId               String?
  cvCreationLimit      Int      @default(10)
  cvCreationsUsed      Int      @default(0)
  applicationLimitUsed Int      @default(0)
  baseCoverLetter      String?
  dummyEmail           String?
  dummyPassword        String?
  preferredLanguage    String   @default("en")
  marketingData        Json?
  onboardingData       Json?

  // Taxonomy-driven structured fields (all nullable for backwards compat)
  currentRoleId        String?
  targetRoleIds        String[] @default([])
  targetIndustryIds    String[] @default([])
  skillIds             String[] @default([])
  yearsExperienceMin   Int?
  yearsExperienceMax   Int?
  salaryMin            Int?
  salaryMax            Int?
  salaryCurrency       String?  @default("EUR")
  baseCity             String?
  baseCountry          String?
  acceptsRemote        Boolean  @default(false)
  willingToRelocate    Boolean  @default(false)
  acceptedCities       String[] @default([])
  candidateLanguages   Json?
  workAuth             String[] @default([])
  careerGoal           String?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan? @relation(fields: [planId], references: [id])
}

model JobRole {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  family      String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([family])
}

model Industry {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Skill {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  families  String[] @default([])
  aliases   String[] @default([])
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CV {
  id              String   @id @default(cuid())
  userId          String
  title           String
  originalFileKey String?
  parsedData      Json?
  editorData      Json?
  htmlContent     String?
  style           String?
  language        String?
  isBase          Boolean  @default(false)
  parentId        String?
  parentType      String?
  generatedForJobId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent CV?  @relation("CVVersions", fields: [parentId], references: [id])
  children CV[] @relation("CVVersions")
  generatedForJob JobDiscovery? @relation(fields: [generatedForJobId], references: [id])
  queueItems CandidateJobQueue[]

  @@index([userId])
}

model CoverLetter {
  id         String   @id @default(cuid())
  userId     String
  title      String
  content    String
  editorData Json?
  language   String?
  isBase     Boolean  @default(false)
  parentId   String?
  parentType String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   CoverLetter? @relation("CLVersions", fields: [parentId], references: [id])
  children CoverLetter[] @relation("CLVersions")
  queueItems CandidateJobQueue[] @relation("QueueCoverLetter")

  @@index([userId])
}

model Application {
  id             String            @id @default(cuid())
  userId         String
  companyName    String
  jobTitle       String
  jobUrl         String?
  status         ApplicationStatus @default(TO_APPLY)
  appliedAt      DateTime?
  notes          String?
  salary         String?
  contactPerson  String?
  nextAction     String?
  jobDescription String?
  cvUsed         String?
  clUsed         String?
  references     String?
  addedById      String?
  source         String?           @default("self")
  screenshotKey  String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  queueItem CandidateJobQueue?

  @@index([userId])
}

model AdminPrompt {
  id        String   @id @default(cuid())
  type      String
  name      String
  prompt    String
  isActive  Boolean  @default(true)
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model JobDiscovery {
  id           String   @id @default(cuid())
  title        String
  company      String
  url          String?
  description  String?
  location     String?
  salary       String?
  requirements String?
  source       String   @default("manual")
  addedById    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Structured fields for deterministic matching (all nullable — free-text
  // jobs still work, they just score lower on fields they can't prove).
  roleId             String?
  roleFamily         String?
  skillIds           String[] @default([])
  industryIds        String[] @default([])
  city               String?
  country            String?
  remote             Boolean  @default(false)
  salaryMin          Int?
  salaryMax          Int?
  salaryCurrency     String?  @default("EUR")
  yearsExperienceMin Int?
  yearsExperienceMax Int?
  languagesRequired  String[] @default([])
  workAuthRequired   String[] @default([])
  seniority          String?
  isPublished        Boolean  @default(true)

  addedBy    User                @relation(fields: [addedById], references: [id])
  queueItems CandidateJobQueue[]
  generatedCvs CV[]

  @@index([addedById])
}

model CandidateJobQueue {
  id             String   @id @default(cuid())
  candidateId    String
  jobId          String
  employeeId     String
  relevanceScore Float?
  reasoning      String?
  matchFactors   Json?
  status         String   @default("PENDING")
  generatedCvId  String?
  generatedClId  String?
  applicationId  String?  @unique
  appliedAt      DateTime?
  createdAt      DateTime @default(now())

  candidate   User          @relation("QueueCandidate", fields: [candidateId], references: [id])
  job         JobDiscovery  @relation(fields: [jobId], references: [id])
  employee    User          @relation("QueueEmployee", fields: [employeeId], references: [id])
  generatedCv CV?           @relation(fields: [generatedCvId], references: [id])
  generatedCl CoverLetter?  @relation("QueueCoverLetter", fields: [generatedClId], references: [id])
  application Application?  @relation(fields: [applicationId], references: [id])

  @@index([candidateId])
  @@index([jobId])
}

model FaqItem {
  id           String   @id @default(cuid())
  candidateId  String
  employeeId   String
  question     String
  answer       String
  category     String?
  isApproved   Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  candidate User @relation("FaqCandidate", fields: [candidateId], references: [id], onDelete: Cascade)
  employee  User @relation("FaqEmployee", fields: [employeeId], references: [id])

  @@index([candidateId])
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  planId          String?
  amount          Float
  currency        String   @default("EUR")
  method          String   @default("platform")
  status          String   @default("paid")
  stripeSessionId String?
  notes           String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan? @relation(fields: [planId], references: [id])

  @@index([userId])
}

model PendingCheckout {
  id              String   @id @default(cuid())
  userId          String
  planId          String
  stripeSessionId String   @unique
  status          String   @default("pending")
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@index([stripeSessionId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  category  String
  detail    String?
  meta      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}
