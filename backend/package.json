{
  "name": "backend",
  "module": "src/server.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env.development -- bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "db:migrate": "dotenv -e .env.development -- bunx prisma migrate dev",
    "db:push": "dotenv -e .env.development -- bunx prisma db push",
    "db:seed": "dotenv -e .env.development -- bunx prisma db seed",
    "db:studio": "dotenv -e .env.development -- bunx prisma studio",
    "docker:up": "docker compose -f dev-docker-compose.yml up -d",
    "docker:down": "docker compose -f dev-docker-compose.yml down"
  },
  "prisma": {
    "seed": "bun prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "dotenv-cli": "^11.0.0",
    "prisma": "^7.4.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1003.0",
    "@aws-sdk/s3-request-presigner": "^3.1003.0",
    "@prisma/client": "^7.4.2",
    "auth0": "^5.4.0",
    "axios": "^1.13.6",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "minio": "^8.0.7",
    "nats": "^2.29.3",
    "openai": "^6.26.0",
    "stripe": "^20.4.0",
    "zod": "^4.3.6"
  }
}
