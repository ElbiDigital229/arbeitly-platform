# Frontend environment variables
# Copy to .env.local for local development

# API proxy target (Vite dev server proxies /api to this)
VITE_API_URL=http://localhost:4000

# Auth0 (optional — only needed when Auth0 is configured)
# VITE_AUTH0_DOMAIN=your-tenant.auth0.com
# VITE_AUTH0_CLIENT_ID=placeholder
# VITE_AUTH0_AUDIENCE=https://api.arbeitly.com

# Stripe (optional — only needed for payment integration)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
